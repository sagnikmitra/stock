# =============================================================================
# Investment Bible OS — Environment Variables
# =============================================================================

# App
NEXT_PUBLIC_APP_NAME=Investment Bible OS
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:54322/investment_bible
DIRECT_URL=postgresql://postgres:password@localhost:54322/investment_bible

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
AUTH_SECRET=change-me-in-production
ADMIN_EMAIL=admin@investmentbible.local
ADMIN_PASSWORD=change-me

# Cache / Queue
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Provider: NSE
NSE_ENABLED=true

# Provider: Zerodha Kite
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Provider: Upstox
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=

# Provider: Shoonya
SHOONYA_ENABLED=false
SHOONYA_USER_ID=
SHOONYA_PASSWORD=
SHOONYA_VENDOR_CODE=
SHOONYA_API_KEY=
SHOONYA_IMEI=

# Provider: Twelve Data
TWELVEDATA_API_KEY=

# Provider: Financial Modeling Prep
FMP_API_KEY=

# Provider: Indian Stock Market API (0xramm, no key required)
INDIAN_STOCK_MARKET_API_BASE_URL=https://nse-api-ruby.vercel.app

# Provider: EOD Historical Data
EODHD_API_KEY=

# Jobs / Cron
CRON_SECRET=change-me-cron-secret
PRE_MARKET_CRON_ENABLED=true
POST_CLOSE_CRON_ENABLED=true
MONTH_END_CRON_ENABLED=true
BACKFILL_CRON_ENABLED=false

# Free data sync (recommended for personal free-only setup)
FREE_DATA_SYNC_ENABLED=true
FREE_QUOTES_PROVIDER_PRIORITY=nse_official,indian_stock_market_api,twelvedata,fmp
FREE_CONTEXT_PROVIDER_PRIORITY=nse_official,twelvedata,fmp
FREE_CANDLE_PROVIDER_PRIORITY=nse_official,twelvedata,fmp
FREE_DATA_PREMARKET_SYMBOL_LIMIT=80
FREE_DATA_POSTCLOSE_SYMBOL_LIMIT=140
FREE_DATA_BOOTSTRAP_DAYS=420
# Hot D1 candle retention in Supabase. Older rows are rebuildable from providers.
FREE_DATA_CANDLE_RETENTION_DAYS=450
# 0 or unset = uncapped NSE universe sync (recommended). Set >0 to cap.
FREE_DATA_SYMBOL_UNIVERSE_LIMIT=0

# Feature Flags
FEATURE_BACKTEST=true
FEATURE_ALERTS=false
FEATURE_HOLDINGS_UPLOAD=false
FEATURE_MUTUAL_FUND_DISCOVERY=true
FEATURE_ADMIN_RULE_EDITOR=true
